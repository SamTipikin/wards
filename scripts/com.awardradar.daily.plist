<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.awardradar.daily</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/samtipikin/Desktop/Wards/scripts/daily-local.sh</string>
  </array>
  <!-- 08:00 local time daily. If the Mac is asleep/off, launchd runs it at the
       next wake/boot (once, as catch-up). -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>8</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>/Users/samtipikin/Desktop/Wards/daily-local.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/samtipikin/Desktop/Wards/daily-local.err.log</string>
  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
